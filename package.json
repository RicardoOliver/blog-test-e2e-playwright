{
  "name": "blog-agi-testes",
  "version": "1.0.0",
  "description": "Automação de testes do Blog do Agi – Playwright + Cucumber BDD (PT-BR)",
  "author": "Time de QA",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "scripts": {
    "instalar-browsers": "playwright install chromium --with-deps",
    "test": "cucumber-js --config cucumber.cjs",
    "test:smoke": "cucumber-js --config cucumber.cjs --tags '@smoke'",
    "test:regressao": "cucumber-js --config cucumber.cjs --tags '@regressao'",
    "test:pesquisa": "cucumber-js --config cucumber.cjs --tags '@pesquisa'",
    "test:navegacao": "cucumber-js --config cucumber.cjs --tags '@navegacao'",
    "test:negativo": "cucumber-js --config cucumber.cjs --tags '@negativo'",
    "test:limite": "cucumber-js --config cucumber.cjs --tags '@limite'",
    "test:edge-case": "cucumber-js --config cucumber.cjs --tags '@edge-case'",
    "test:headed": "cross-env HEADLESS=false cucumber-js --config cucumber.cjs",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js --config cucumber.cjs",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js --config cucumber.cjs",
    "relatorio": "allure generate relatorios/allure-results --clean -o relatorios/allure-report && allure open relatorios/allure-report",
    "relatorio:gerar": "allure generate relatorios/allure-results --clean -o relatorios/allure-report",
    "limpar": "rimraf relatorios/ *.log"
  },
  "dependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.51.1",
    "playwright": "^1.51.1",
    "allure-cucumberjs": "^3.3.0",
    "allure-js-commons": "^3.3.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1"
  }
}
