# =============================================================================
#  .env – Configurações padrão dos testes
#  Blog do Agi – Automação de Testes (JavaScript)
#
#  ⚠️  Nunca versionar este arquivo com dados sensíveis.
#      Para ambientes CI, use variáveis de ambiente do runner.
# =============================================================================

# ── Browser ──────────────────────────────────────────────────────────────────
BROWSER=chromium
HEADLESS=true
SLOW_MOTION=0
VIEWPORT_LARGURA=1280
VIEWPORT_ALTURA=720

# ── URLs ─────────────────────────────────────────────────────────────────────
URL_BASE=https://blog.agibank.com.br

# ── Timeouts (em milissegundos) ───────────────────────────────────────────────
TIMEOUT_NAVEGACAO=60000
TIMEOUT_ELEMENTO=10000
TIMEOUT_PADRAO=30000

# ── Evidências ────────────────────────────────────────────────────────────────
SCREENSHOT_EM_FALHA=true
SCREENSHOT_DIRETORIO=relatorios/screenshots

# ── Locale ────────────────────────────────────────────────────────────────────
LOCALE=pt-BR
TIMEZONE=America/Sao_Paulo
