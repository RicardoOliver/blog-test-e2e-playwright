# =============================================================================
#  .env.example – Copie para .env e ajuste os valores
#  Nunca versione o .env com dados reais!
# =============================================================================

BROWSER=chromium           # chromium | firefox | webkit
HEADLESS=true              # true | false
SLOW_MOTION=0              # ms de atraso entre ações (útil para debug)
VIEWPORT_LARGURA=1280
VIEWPORT_ALTURA=720

URL_BASE=https://blog.agibank.com.br

TIMEOUT_NAVEGACAO=60000    # ms
TIMEOUT_ELEMENTO=10000     # ms
TIMEOUT_PADRAO=30000       # ms

SCREENSHOT_EM_FALHA=true
SCREENSHOT_DIRETORIO=relatorios/screenshots

LOCALE=pt-BR
TIMEZONE=America/Sao_Paulo
